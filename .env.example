NODE_ENV=development
PORT=3000
DATABASE_URL=file:./dev.db

JWT_SECRET=dev-secret-change-in-production
JWT_ISSUER=timeoff-service
JWT_AUDIENCE=timeoff-api

WORKDAY_TENANT_HOSTNAME=localhost:4001
WORKDAY_CLIENT_ID=mock-client-id
WORKDAY_CLIENT_SECRET=mock-client-secret
WORKDAY_REFRESH_TOKEN=mock-refresh-token
HCM_MOCK_MODE=true

CRON_NIGHTLY_HCM_SYNC=0 2 * * *
CRON_APPROVAL_REMINDER=0 9 * * 1-5
CRON_HCM_APPROVAL_RETRY=0 * * * *
HCM_APPROVAL_RETRY_WINDOW_HOURS=24

WORKDAY_SUBMITTED_ACTION_WID=d9e4223e446c11de98360015c5e6daf6
WORKDAY_PREFLIGHT_ENABLED=false

LOG_LEVEL=info
