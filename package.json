{
  "name": "timeoff-service",
  "version": "0.1.0",
  "description": "MyCompany Time Off Management Microservice",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage tests/unit",
    "test:integration:coverage": "vitest run --coverage tests/integration",
    "test:coverage:all": "vitest run --coverage",
    "test:watch": "vitest tests/unit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "mock:workday": "tsx tools/workday-mock/server.ts",
    "tools:jwt": "tsx bin/tools/create-jwt.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/client": "^6.0.0",
    "decimal.js": "^10.4.3",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "node-cron": "^3.0.3",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^2.1.0",
    "fast-jwt": "^5.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.0"
  }
}
